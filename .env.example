# ---- Gemini Exchange ----
# Sandbox : https://exchange.sandbox.gemini.com/
GEMINI_API_KEY=
GEMINI_API_SECRET=
GEMINI_SANDBOX=true

# ---- OpenRouter (LLM agent, free tier) ----
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ---- Données financières ----
FINNHUB_API_KEY=

# ---- Reddit PRAW (sentiment social) ----
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=gemini-trader/0.1 by yourname

# ---- Observabilité ----
METRICS_PORT=8000

# ---- Storage ----
SQLITE_PATH=./data/trader.db
